{
	"version": 10,
	"configurePresets": [
		{
			"name": "ninja-multi",
			"hidden": true,
			"generator": "Ninja Multi-Config",
			"binaryDir": "${sourceDir}/build/${presetName}",
			"cacheVariables": { "CMAKE_DEFAULT_BUILD_TYPE": "Release" }
		},
		{
			"name": "android-arm64",
			"inherits": "ninja-multi",
			"toolchainFile": "$env{IMAGINE_PATH}/cmake/android-arm64.cmake"
		},
		{
			"name": "android-armv7",
			"inherits": "ninja-multi",
			"toolchainFile": "$env{IMAGINE_PATH}/cmake/android-armv7.cmake"
		},
		{
			"name": "android-x86_64",
			"inherits": "ninja-multi",
			"toolchainFile": "$env{IMAGINE_PATH}/cmake/android-x86_64.cmake"
		},
		{
			"name": "android-x86",
			"inherits": "ninja-multi",
			"toolchainFile": "$env{IMAGINE_PATH}/cmake/android-x86.cmake"
		},
		{
			"name": "linux-x86_64",
			"inherits": "ninja-multi",
			"toolchainFile": "$env{IMAGINE_PATH}/cmake/linux-x86_64.cmake"
		},
		{
			"name": "linux-armv7-pandora",
			"inherits": "ninja-multi",
			"toolchainFile": "$env{IMAGINE_PATH}/cmake/linux-armv7-pandora.cmake"
		},
		{
			"name": "ios-arm64",
			"inherits": "ninja-multi",
			"toolchainFile": "$env{IMAGINE_PATH}/cmake/ios-arm64.cmake"
		},
		{
			"name": "ios-armv7",
			"inherits": "ninja-multi",
			"toolchainFile": "$env{IMAGINE_PATH}/cmake/ios-armv7.cmake"
		}
	],
	"buildPresets": [
		{
			"name": "android-arm64-debug",
			"configurePreset": "android-arm64",
			"configuration": "Debug"
		},
		{
			"name": "android-arm64-release",
			"configurePreset": "android-arm64",
			"configuration": "Release"
		},
		{
			"name": "android-arm64-release+debug",
			"configurePreset": "android-arm64",
			"configuration": "RelWithDebInfo"
		},
		{
			"name": "android-armv7-debug",
			"configurePreset": "android-armv7",
			"configuration": "Debug"
		},
		{
			"name": "android-armv7-release",
			"configurePreset": "android-armv7",
			"configuration": "Release"
		},
		{
			"name": "android-armv7-release+debug",
