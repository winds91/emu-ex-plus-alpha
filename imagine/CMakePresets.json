			"configuration": "Debug"
		},
		{
			"name": "linux-x86_64-release",
			"configurePreset": "linux-x86_64",
			"configuration": "Release"
		},
		{
			"name": "linux-x86_64-release+debug",
			"configurePreset": "linux-x86_64",
			"configuration": "RelWithDebInfo"
		},
		{
			"name": "linux-armv7-pandora-debug",
			"configurePreset": "linux-armv7-pandora",
			"configuration": "Debug"
