			"configuration": "Release"
		},
		{
			"name": "ios-arm64-release+debug",
			"configurePreset": "ios-arm64",
			"configuration": "RelWithDebInfo"
		},
		{
			"name": "ios-armv7-debug",
			"configurePreset": "ios-armv7",
			"configuration": "Debug"
		},
		{
			"name": "ios-armv7-release",
			"configurePreset": "ios-armv7",
			"configuration": "Release"
		},
		{
			"name": "ios-armv7-release+debug",
			"configurePreset": "ios-armv7",
